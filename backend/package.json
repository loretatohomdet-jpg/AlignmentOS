{
  "name": "alignment-index-backend",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "prisma migrate deploy && node server.js",
    "dev": "node server.js",
    "db:start": "bash scripts/start-postgres.sh",
    "db:fix": "bash scripts/fix-pg-hba.sh",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate",
    "seed": "npx prisma db seed",
    "test": "node --test tests/*.test.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "prisma": "^6.19.2",
    "resend": "^6.9.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.11.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
