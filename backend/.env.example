# Database (required)
# If nothing is listening on 127.0.0.1:5432, start Postgres from the repo root:
#   docker compose up -d
# Then run migrations: cd backend && npx prisma migrate deploy
DATABASE_URL="postgresql://alignment:alignment@127.0.0.1:5432/alignment_index_db?schema=public"

# Auth (required in production — use a long random string)
JWT_SECRET="your-secret-here"

# Optional: frontend URL for password-reset and welcome emails
APP_URL="http://localhost:5173"

# Optional: restrict CORS to your frontend (e.g. in production)
# CORS_ORIGIN="https://your-frontend-domain.com"

# Optional: Resend for welcome email (lead capture) and password-reset email
# RESEND_API_KEY="re_..."
# RESEND_FROM="Alignment OS <onboarding@yourdomain.com>"

# Optional: OpenAI for AI Agent
# OPENAI_API_KEY="sk-..."
# OPENAI_AGENT_MODEL="gpt-4o-mini"
